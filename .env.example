# Supabase project credentials (publishable / anon key — safe for the browser)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxx

# AirLabs flight data (https://airlabs.co/docs) — used by /api/flights/* for
# flight-number autocomplete and live status. Server-side only: do NOT prefix
# with NEXT_PUBLIC_ (that would leak the key to the browser).
AIRLABS_API_KEY=your_key_here
